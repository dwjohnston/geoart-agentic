{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GeoArt Graph",
  "description": "Serialised dataflow graph for the Geometric Art Engine",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "control", "compute", "render"],
  "properties": {
    "version": {
      "type": "string",
      "description": "major.minor — increment minor for backward-compatible additions, major for breaking changes",
      "pattern": "^\\d+\\.\\d+$"
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/definitions/controlNode" }
        }
      }
    },
    "compute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/definitions/computeNode" }
        }
      }
    },
    "render": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/definitions/renderNode" }
        }
      }
    }
  },
  "definitions": {
    "refParam": {
      "type": "object",
      "description": "A reference to another node's named output port, in the form 'nodeId.portName'",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": {
          "type": "string",
          "description": "Reference in the form 'nodeId.portName'",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*\\.[a-zA-Z][a-zA-Z0-9_-]*$"
        }
      }
    },
    "staticNumberParam": {
      "type": "object",
      "description": "A numeric parameter — static value only, no ref (used in control nodes)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": { "type": "number" },
        "locked": { "type": "boolean" },
        "comment": { "type": "string" }
      }
    },
    "staticStringParam": {
      "type": "object",
      "description": "A string parameter — static value only, no ref (used in control nodes)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": { "type": "string" },
        "locked": { "type": "boolean" },
        "comment": { "type": "string" }
      }
    },
    "staticBooleanParam": {
      "type": "object",
      "description": "A boolean parameter — static value only, no ref (used in control nodes)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": { "type": "boolean" },
        "locked": { "type": "boolean" },
        "comment": { "type": "string" }
      }
    },
    "staticColorParam": {
      "type": "object",
      "description": "A colour parameter — static value only, no ref (used in control nodes)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": { "$ref": "#/definitions/colorValue" },
        "locked": { "type": "boolean" },
        "comment": { "type": "string" }
      }
    },
    "numberParam": {
      "description": "A numeric parameter — static value or reference to another node's output",
      "oneOf": [
        { "$ref": "#/definitions/staticNumberParam" },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "stringParam": {
      "description": "A string or enum parameter — static value or reference to another node's output",
      "oneOf": [
        { "$ref": "#/definitions/staticStringParam" },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "booleanParam": {
      "description": "A boolean parameter — static value or reference to another node's output",
      "oneOf": [
        { "$ref": "#/definitions/staticBooleanParam" },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "colorValue": {
      "type": "object",
      "description": "RGBA colour with each component in 0–1",
      "additionalProperties": false,
      "required": ["r", "g", "b", "a"],
      "properties": {
        "r": { "type": "number", "minimum": 0, "maximum": 1 },
        "g": { "type": "number", "minimum": 0, "maximum": 1 },
        "b": { "type": "number", "minimum": 0, "maximum": 1 },
        "a": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "colorParam": {
      "description": "A colour parameter — static value or reference to another node's output",
      "oneOf": [
        { "$ref": "#/definitions/staticColorParam" },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "pointValue": {
      "type": "object",
      "description": "A 2-D point in normalised space (-1 to 1 per axis)",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "pointParam": {
      "description": "A 2-D point parameter — static value or reference to another node's output",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["v"],
          "properties": {
            "v": { "$ref": "#/definitions/pointValue" },
            "locked": { "type": "boolean" },
            "comment": { "type": "string" }
          }
        },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "stringArrayParam": {
      "type": "object",
      "description": "An array-of-strings parameter value envelope (used for dropdown options)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": {
          "type": "array",
          "items": { "type": "string" }
        },
        "locked": { "type": "boolean" },
        "comment": { "type": "string" }
      }
    },
    "renderConfig": {
      "type": "object",
      "description": "Controls which canvas layer the render node draws to",
      "additionalProperties": false,
      "required": ["layer"],
      "properties": {
        "layer": {
          "type": "string",
          "enum": ["paint", "live"],
          "description": "paint = accumulates on trail canvas; live = cleared-each-frame orbit canvas"
        }
      }
    },
    "controlNode": {
      "description": "User-facing input node — pure value source with no inputs",
      "oneOf": [
        {
          "type": "object",
          "description": "Numeric slider",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "type": "string" },
            "type": { "type": "string", "enum": ["slider"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "label": { "$ref": "#/definitions/staticStringParam" },
                "min":   { "$ref": "#/definitions/staticNumberParam" },
                "max":   { "$ref": "#/definitions/staticNumberParam" },
                "value": { "$ref": "#/definitions/staticNumberParam" },
                "step":  {"$ref": "#/definitions/staticNumberParam"}
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Color picker",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "type": "string" },
            "type": { "type": "string", "enum": ["colorPicker"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "label": { "$ref": "#/definitions/staticStringParam" },
                "value": { "$ref": "#/definitions/staticColorParam" }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "String dropdown / enum selector",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "type": "string" },
            "type": { "type": "string", "enum": ["dropdown"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "label":   { "$ref": "#/definitions/staticStringParam" },
                "options": { "$ref": "#/definitions/stringArrayParam" },
                "value":   { "$ref": "#/definitions/staticStringParam" }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Boolean toggle — emits a trigger when on",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "type": "string" },
            "type": { "type": "string", "enum": ["toggle"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "label": { "$ref": "#/definitions/staticStringParam" },
                "value": { "$ref": "#/definitions/staticBooleanParam" }
              }
            }
          }
        }
      ]
    },
    "computeNode": {
      "description": "Pure math node — no canvas, no DOM, no side effects",
      "oneOf": [
        {
          "type": "object",
          "description": "Emits elapsed time in seconds",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "type": "string" },
            "type": { "type": "string", "enum": ["time"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {}
            }
          }
        },
        {
          "type": "object",
          "description": "Oscillation generator — sine, saw, or square wave",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "type": "string" },
            "type": { "type": "string", "enum": ["wave"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "time":      { "$ref": "#/definitions/numberParam" },
                "waveType":  { "$ref": "#/definitions/stringParam" },
                "frequency": { "$ref": "#/definitions/numberParam" },
                "phase":     { "$ref": "#/definitions/numberParam" }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Circular motion — outputs an x/y point",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "type": "string" },
            "type": { "type": "string", "enum": ["orbit"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "time":   { "$ref": "#/definitions/numberParam" },
                "radius": { "$ref": "#/definitions/numberParam" },
                "speed":  { "$ref": "#/definitions/numberParam" },
                "center": { "$ref": "#/definitions/pointParam" }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Maps an input range to an output range",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "type": "string" },
            "type": { "type": "string", "enum": ["scale"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "inMin":  { "$ref": "#/definitions/numberParam" },
                "inMax":  { "$ref": "#/definitions/numberParam" },
                "outMin": { "$ref": "#/definitions/numberParam" },
                "outMax": { "$ref": "#/definitions/numberParam" }
              }
            }
          }
        }
      ]
    },
    "renderNode": {
      "description": "Drawing node — canvas access lives here and nowhere else",
      "oneOf": [
        {
          "type": "object",
          "description": "Draws a line between two points on an interval",
          "additionalProperties": false,
          "required": ["id", "type", "renderConfig", "params"],
          "properties": {
            "id":           { "type": "string" },
            "type":         { "type": "string", "enum": ["timedLine"] },
            "renderConfig": { "$ref": "#/definitions/renderConfig" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "intervalMs": { "$ref": "#/definitions/numberParam" },
                "pointA":     { "$ref": "#/definitions/pointParam" },
                "pointB":     { "$ref": "#/definitions/pointParam" },
                "color":      { "$ref": "#/definitions/colorParam" }
              }
            }
          }
        },
        {
          "type": "object",
          "description": "Draws a circle at a point",
          "additionalProperties": false,
          "required": ["id", "type", "renderConfig", "params"],
          "properties": {
            "id":           { "type": "string" },
            "type":         { "type": "string", "enum": ["circle"] },
            "renderConfig": { "$ref": "#/definitions/renderConfig" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "intervalMs": { "$ref": "#/definitions/numberParam" },
                "center":     { "$ref": "#/definitions/pointParam" },
                "radius":     { "$ref": "#/definitions/numberParam" },
                "color":      { "$ref": "#/definitions/colorParam" }
              }
            }
          }
        }
      ]
    }
  }
}
