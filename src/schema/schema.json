{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GeoArt Graph",
  "description": "Serialised dataflow graph for the Geometric Art Engine",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "control", "compute", "render"],
  "properties": {
    "version": {
      "title": "Version",
      "type": "string",
      "description": "major.minor — increment minor for backward-compatible additions, major for breaking changes",
      "pattern": "^\\d+\\.\\d+$"
    },
    "speed": {
      "title": "Global Speed",
      "type": "number",
      "description": "Global playback speed. Values >= 1 run that many ticks per frame. Values < 1 must be unit fractions (1/2, 1/3, …) — one tick every n frames. Default 1.",
      "minimum": 0.125
    },
    "control": {
      "title": "Control Section",
      "description": "User-facing input nodes — sliders, colour pickers, and dropdowns",
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "title": "Control Nodes",
          "type": "array",
          "items": { "$ref": "#/definitions/controlNode" }
        }
      }
    },
    "compute": {
      "title": "Compute",
      "description": "Pure math nodes — no canvas, no DOM, no side effects",
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "title": "Nodes",
          "type": "array",
          "items": { "$ref": "#/definitions/computeNode" }
        }
      }
    },
    "render": {
      "title": "Render",
      "description": "Drawing nodes — canvas access lives here and nowhere else",
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes"],
      "properties": {
        "nodes": {
          "title": "Nodes",
          "type": "array",
          "items": { "$ref": "#/definitions/renderNode" }
        }
      }
    }
  },
  "definitions": {
    "lockedProp": {
      "title": "Locked",
      "description": "When true the value cannot be changed via the UI",
      "type": "boolean"
    },
    "commentProp": {
      "title": "Comment",
      "description": "Optional human-readable annotation for this param",
      "type": "string"
    },
    "refParam": {
      "title": "Ref Param",
      "type": "object",
      "description": "A reference to another node's named output port, in the form 'nodeId.portName'",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": {
          "title": "Ref",
          "description": "Reference in the form 'nodeId.portName'",
          "type": "string",
          "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*\\.[a-zA-Z][a-zA-Z0-9_-]*$"
        }
      }
    },
    "staticNumberParam": {
      "title": "Static Number Param",
      "type": "object",
      "description": "A numeric parameter — static value only, no ref (used in control nodes)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": { "title": "Value", "type": "number" },
        "locked":  { "$ref": "#/definitions/lockedProp" },
        "comment": { "$ref": "#/definitions/commentProp" }
      }
    },
    "staticStringParam": {
      "title": "Static String Param",
      "type": "object",
      "description": "A string parameter — static value only, no ref (used in control nodes)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": { "title": "Value", "type": "string" },
        "locked":  { "$ref": "#/definitions/lockedProp" },
        "comment": { "$ref": "#/definitions/commentProp" }
      }
    },
    "staticBooleanParam": {
      "title": "Static Boolean Param",
      "type": "object",
      "description": "A boolean parameter — static value only, no ref (used in control nodes)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": { "title": "Value", "type": "boolean" },
        "locked":  { "$ref": "#/definitions/lockedProp" },
        "comment": { "$ref": "#/definitions/commentProp" }
      }
    },
    "staticColorParam": {
      "title": "Static Color Param",
      "type": "object",
      "description": "A colour parameter — static value only, no ref (used in control nodes)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": { "$ref": "#/definitions/colorValue" },
        "locked":  { "$ref": "#/definitions/lockedProp" },
        "comment": { "$ref": "#/definitions/commentProp" }
      }
    },
    "numberParam": {
      "title": "Number Param",
      "description": "A numeric parameter — static value or reference to another node's output",
      "oneOf": [
        { "$ref": "#/definitions/staticNumberParam" },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "stringParam": {
      "title": "String Param",
      "description": "A string or enum parameter — static value or reference to another node's output",
      "oneOf": [
        { "$ref": "#/definitions/staticStringParam" },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "waveTypeEnumParam": {
      "title": "Wave Type Enum Param",
      "description": "Wave shape selector — sine, square, saw, inverse-saw, or triangle",
      "oneOf": [
        {
          "title": "Static Wave Type",
          "type": "object",
          "description": "Statically selected wave shape",
          "additionalProperties": false,
          "required": ["v"],
          "properties": {
            "v": {
              "title": "Value",
              "description": "Selected wave shape",
              "type": "string",
              "enum": ["sine", "square", "saw", "inverse-saw", "triangle"]
            },
            "locked":  { "$ref": "#/definitions/lockedProp" },
            "comment": { "$ref": "#/definitions/commentProp" }
          }
        },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "booleanParam": {
      "title": "Boolean Param",
      "description": "A boolean parameter — static value or reference to another node's output",
      "oneOf": [
        { "$ref": "#/definitions/staticBooleanParam" },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "colorValue": {
      "title": "Color Value",
      "type": "object",
      "description": "RGBA colour with each component in 0–1",
      "additionalProperties": false,
      "required": ["r", "g", "b", "a"],
      "properties": {
        "r": { "title": "Red",   "description": "Red channel (0–1)",   "type": "number", "minimum": 0, "maximum": 1 },
        "g": { "title": "Green", "description": "Green channel (0–1)", "type": "number", "minimum": 0, "maximum": 1 },
        "b": { "title": "Blue",  "description": "Blue channel (0–1)",  "type": "number", "minimum": 0, "maximum": 1 },
        "a": { "title": "Alpha", "description": "Alpha channel (0–1)", "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "colorParam": {
      "title": "Color Param",
      "description": "A colour parameter — static value or reference to another node's output",
      "oneOf": [
        { "$ref": "#/definitions/staticColorParam" },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "pointValue": {
      "title": "Point Value",
      "type": "object",
      "description": "A 2-D point in normalised space (-1 to 1 per axis)",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "title": "X", "description": "Horizontal position in normalised space (-1 to 1)", "type": "number" },
        "y": { "title": "Y", "description": "Vertical position in normalised space (-1 to 1)",   "type": "number" }
      }
    },
    "pointParam": {
      "title": "Point Param",
      "description": "A 2-D point parameter — static value or reference to another node's output",
      "oneOf": [
        {
          "title": "Static Point",
          "type": "object",
          "description": "Statically defined 2-D point",
          "additionalProperties": false,
          "required": ["v"],
          "properties": {
            "v":       { "$ref": "#/definitions/pointValue" },
            "locked":  { "$ref": "#/definitions/lockedProp" },
            "comment": { "$ref": "#/definitions/commentProp" }
          }
        },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "colorPointValue": {
      "title": "Color Point Value",
      "type": "object",
      "description": "A 2-D point in normalised space (-1 to 1 per axis) combined with an RGBA colour",
      "additionalProperties": false,
      "required": ["x", "y", "r", "g", "b", "a"],
      "properties": {
        "x": { "title": "X",     "description": "Horizontal position in normalised space (-1 to 1)", "type": "number" },
        "y": { "title": "Y",     "description": "Vertical position in normalised space (-1 to 1)",   "type": "number" },
        "r": { "title": "Red",   "description": "Red channel (0–1)",   "type": "number", "minimum": 0, "maximum": 1 },
        "g": { "title": "Green", "description": "Green channel (0–1)", "type": "number", "minimum": 0, "maximum": 1 },
        "b": { "title": "Blue",  "description": "Blue channel (0–1)",  "type": "number", "minimum": 0, "maximum": 1 },
        "a": { "title": "Alpha", "description": "Alpha channel (0–1)", "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "colorPointParam": {
      "title": "Color Point Param",
      "description": "A coloured point parameter — static value or reference to another node's output",
      "oneOf": [
        {
          "title": "Static Color Point",
          "type": "object",
          "description": "Statically defined coloured point",
          "additionalProperties": false,
          "required": ["v"],
          "properties": {
            "v":       { "$ref": "#/definitions/colorPointValue" },
            "locked":  { "$ref": "#/definitions/lockedProp" },
            "comment": { "$ref": "#/definitions/commentProp" }
          }
        },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "colorPointArrayParam": {
      "title": "Color Point Array Param",
      "description": "An array of coloured points parameter — static value or reference to another node's output",
      "oneOf": [
        {
          "title": "Static Color Point Array",
          "type": "object",
          "description": "Statically defined array of coloured points",
          "additionalProperties": false,
          "required": ["v"],
          "properties": {
            "v": {
              "title": "Value",
              "description": "Array of coloured point values",
              "type": "array",
              "items": { "$ref": "#/definitions/colorPointValue" }
            },
            "locked":  { "$ref": "#/definitions/lockedProp" },
            "comment": { "$ref": "#/definitions/commentProp" }
          }
        },
        { "$ref": "#/definitions/refParam" }
      ]
    },
    "stringArrayParam": {
      "title": "String Array Param",
      "type": "object",
      "description": "An array-of-strings parameter value envelope (used for dropdown options)",
      "additionalProperties": false,
      "required": ["v"],
      "properties": {
        "v": {
          "title": "Value",
          "description": "Array of option strings",
          "type": "array",
          "items": { "type": "string" }
        },
        "locked":  { "$ref": "#/definitions/lockedProp" },
        "comment": { "$ref": "#/definitions/commentProp" }
      }
    },
    "renderConfig": {
      "title": "Render Layer Config",
      "type": "object",
      "description": "Controls which canvas layer the render node draws to",
      "additionalProperties": false,
      "required": ["layer"],
      "properties": {
        "layer": {
          "title": "Layer",
          "description": "paint = accumulates on trail canvas; live = cleared-each-frame orbit canvas",
          "type": "string",
          "enum": ["paint", "live"]
        }
      }
    },
    "controlNode": {
      "title": "Control Node",
      "description": "User-facing input node — pure value source with no inputs",
      "oneOf": [
        {
          "title": "Slider Control Node",
          "type": "object",
          "description": "Numeric slider",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID",    "type": "string" },
            "type": { "title": "Type",      "type": "string", "enum": ["slider"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "label": { "$ref": "#/definitions/staticStringParam" },
                "min":   { "$ref": "#/definitions/staticNumberParam" },
                "max":   { "$ref": "#/definitions/staticNumberParam" },
                "value": { "$ref": "#/definitions/staticNumberParam" },
                "step":  { "$ref": "#/definitions/staticNumberParam" }
              }
            }
          }
        },
        {
          "title": "Color Picker Control Node",
          "type": "object",
          "description": "Color picker",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID",   "type": "string" },
            "type": { "title": "Type",          "type": "string", "enum": ["colorPicker"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "label": { "$ref": "#/definitions/staticStringParam" },
                "value": { "$ref": "#/definitions/staticColorParam" }
              }
            }
          }
        },
        {
          "title": "Dropdown Control Node",
          "type": "object",
          "description": "String dropdown / enum selector",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID",    "type": "string" },
            "type": { "title": "Type",        "type": "string", "enum": ["dropdown"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "label":   { "$ref": "#/definitions/staticStringParam" },
                "options": { "$ref": "#/definitions/stringArrayParam" },
                "value":   { "$ref": "#/definitions/staticStringParam" }
              }
            }
          }
        }
      ]
    },
    "computeNode": {
      "title": "Compute Node",
      "description": "Pure math node — no canvas, no DOM, no side effects",
      "oneOf": [
        {
          "title": "Tick Compute Node",
          "type": "object",
          "description": "Emits the current tick count",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID",   "type": "string" },
            "type": { "title": "Type",     "type": "string", "enum": ["time"] },
            "params": {

              "type": "object",
              "additionalProperties": false,
              "properties": {}
            }
          }
        },
        {
          "title": "Wave Compute Node",
          "type": "object",
          "description": "Oscillation generator — sine, square, saw, inverse-saw, or triangle wave",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID",   "type": "string" },
            "type": { "title": "Type",      "type": "string", "enum": ["wave"] },
            "params": {
   
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "time":      { "$ref": "#/definitions/numberParam" },
                "waveType":  { "$ref": "#/definitions/waveTypeEnumParam" },
                "frequency": { "$ref": "#/definitions/numberParam" },
                "amplitude": { "$ref": "#/definitions/numberParam" },
                "phase":     { "$ref": "#/definitions/numberParam" }
              }
            }
          }
        },
        {
          "title": "Orbit Compute Node",
          "type": "object",
          "description": "Circular motion — outputs a single point (backwards-compat) and an array of evenly-spaced coloured points",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID",  "type": "string" },
            "type": { "title": "Type",          "type": "string", "enum": ["orbit"] },
            "params": {

              "type": "object",
              "additionalProperties": false,
              "properties": {
                "time":      { "$ref": "#/definitions/numberParam" },
                "radius":    { "$ref": "#/definitions/numberParam" },
                "speed":     { "$ref": "#/definitions/numberParam" },
                "center":    { "$ref": "#/definitions/pointParam" },
                "numPoints": { "$ref": "#/definitions/numberParam" },
                "phase":     { "$ref": "#/definitions/numberParam" }
              }
            }
          }
        },
        {
          "title": "Color Point Compute Node",
          "type": "object",
          "description": "Packs a point and colour into a single coloured-point value",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID",   "type": "string" },
            "type": { "title": "Type",          "type": "string", "enum": ["colorPoint"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "point": { "$ref": "#/definitions/pointParam" },
                "color": { "$ref": "#/definitions/colorParam" }
              }
            }
          }
        },
        {
          "title": "Points On A Line Compute Node",
          "type": "object",
          "description": "Generates evenly-spaced colour points along a line between two colour points",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID",  "type": "string" },
            "type": { "title": "Type",         "type": "string", "enum": ["pointsOnALine"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "pointA":         { "$ref": "#/definitions/colorPointParam" },
                "pointB":         { "$ref": "#/definitions/colorPointParam" },
                "numberOfPoints": { "$ref": "#/definitions/numberParam" }
              }
            }
          }
        },
        {
          "title": "Multiplier Compute Node",
          "type": "object",
          "description": "Multiplies two numbers — outputs product = a * b",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID",   "type": "string" },
            "type": { "title": "Type",      "type": "string", "enum": ["multiplier"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a": { "$ref": "#/definitions/numberParam" },
                "b": { "$ref": "#/definitions/numberParam" }
              }
            }
          }
        },
        {
          "title": "Add Compute Node",
          "type": "object",
          "description": "Adds two numbers — outputs sum = a + b",
          "additionalProperties": false,
          "required": ["id", "type", "params"],
          "properties": {
            "id":   { "title": "ID", "type": "string" },
            "type": { "title": "Type",       "type": "string", "enum": ["add"] },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a": { "$ref": "#/definitions/numberParam" },
                "b": { "$ref": "#/definitions/numberParam" }
              }
            }
          }
        }
      ]
    },
    "renderNode": {
      "title": "Render Node",
      "description": "Drawing node — canvas access lives here and nowhere else",
      "oneOf": [
        {
          "title": "Timed Line Render Node",
          "type": "object",
          "description": "Draws a gradient line between two coloured points on an interval",
          "additionalProperties": false,
          "required": ["id", "type", "renderConfig", "params"],
          "properties": {
            "id":           { "title": "ID",                       "type": "string" },
            "type":         { "title": "Type",                           "type": "string", "enum": ["timedLine"] },
            "renderConfig": { "$ref": "#/definitions/renderConfig" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "intervalTicks": { "$ref": "#/definitions/numberParam" },
                "colorPointA":   { "$ref": "#/definitions/colorPointParam" },
                "colorPointB":   { "$ref": "#/definitions/colorPointParam" }
              }
            }
          }
        },
        {
          "title": "Timed Line Array Render Node",
          "type": "object",
          "description": "Draws gradient lines from each point in one array to the corresponding point in another array, on an interval",
          "additionalProperties": false,
          "required": ["id", "type", "renderConfig", "params"],
          "properties": {
            "id":           { "title": "ID",                      "type": "string" },
            "type":         { "title": "Type",                           "type": "string", "enum": ["timedLineArray"] },
            "renderConfig": { "$ref": "#/definitions/renderConfig" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "intervalTicks": { "$ref": "#/definitions/numberParam" },
                "colorPointsA":  { "$ref": "#/definitions/colorPointArrayParam" },
                "colorPointsB":  { "$ref": "#/definitions/colorPointArrayParam" }
              }
            }
          }
        },
        {
          "title": "Circle Render Node",
          "type": "object",
          "description": "Draws a circle at a point",
          "additionalProperties": false,
          "required": ["id", "type", "renderConfig", "params"],
          "properties": {
            "id":           { "title": "ID",                  "type": "string" },
            "type":         { "title": "Type",                           "type": "string", "enum": ["circle"] },
            "renderConfig": { "$ref": "#/definitions/renderConfig" },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "intervalTicks": { "$ref": "#/definitions/numberParam" },
                "center":        { "$ref": "#/definitions/pointParam" },
                "radius":        { "$ref": "#/definitions/numberParam" },
                "color":         { "$ref": "#/definitions/colorParam" }
              }
            }
          }
        }
      ]
    }
  }
}
