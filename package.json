{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "bun",
      "version": "^1.3.14"
    },
    "packageManager": {
      "name": "bun",
      "version": "^1.3.14"
    }
  },
  "scripts": {
    "validate": "bun clean && bun generate && concurrently    \"bun validate:schema\" \"bun test\" \"bun typecheck\"  \"bunx lint-staged\"",
    "validate:schema": "bun src/schema/scripts/validateSchemaStructure.ts",
    "dev": "vite",
    "build": "tsgo -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsgo -p tsconfig.app.json --noEmit",
    "preview": "vite preview",
    "pretest": "npm run generate",
    "clean": "find src -type d -name '_generated' -exec rm -rf {} + ; find src -type f -name '*.generated*' -delete",
    "test:browser": "npx vitest --browser=chromium",
    "test:browser:headless": "vitest --browser.headless",
    "generate:agents": "bun scripts/generate-agent-files.ts",
    "generate": "bun generate:derived-schema && bun generate:derived-types && bun generate:registries && bun generate:algorithms-index",
    "generate:registries": "bun src/nodes/scripts/generate-registries.ts",
    "generate:algorithms-index": "bun src/algorithms/scripts/generate-algorithms-index.ts",
    "generate:derived-schema": "bun src/schema/scripts/generate-derived-schema.ts",
    "generate:derived-types": "mkdir -p src/schema/_generated && json2ts -i src/schema/schema/schema.json -o src/schema/_generated/schema-types.d.ts --cwd=src/schema/schema && bun src/schema/scripts/generate-derived-types.ts",
    "docs:generate": "bun run scripts/generate-openapi.ts",
    "docs": "bun run docs:generate && vite --config vite.config.docs.ts",
    "docs:build": "bun run docs:generate && vite build --config vite.config.docs.ts",
    "docs:server": "vite preview --config vite.config.docs.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vitest-browser-react": "^2.2.0"
  },
  "devDependencies": {
    "envalid": "^8.1.1",
    "eslint-plugin-import": "^2.32.0",
    "@eslint/js": "^9.39.4",
    "@happy-dom/global-registrator": "^20.8.9",
    "@napi-rs/canvas": "^1.0.0",
    "@types/bun": "^1.3.13",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@typescript/native-preview": "^7.0.0-dev.20260421.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "ajv": "^8.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "from": "^0.1.7",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "import": "^0.0.6",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^17.0.4",
    "playwright": "^1.60.0",
    "semver": "^7.7.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.5"
  }
}