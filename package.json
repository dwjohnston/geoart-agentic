{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "bun",
      "range": "^1.2.2"
    },
    "packageManager": {
      "name": "bun",
      "range": "^1.2.2"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "preview": "vite preview",
    "pretest": "npm run generate:schema-types",
    "test": "vitest",
    "test:headless": "vitest --browser.headless",
    "generate:schema-types": "mkdir -p src/schema/_generated && json2ts -i src/schema/schema.json -o src/schema/_generated/schema-types.d.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@happy-dom/global-registrator": "^20.8.9",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.3",
    "@vitest/browser-playwright": "^4.1.3",
    "ajv": "^8.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "json-schema-to-typescript": "^15.0.4",
    "playwright": "^1.59.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  }
}
